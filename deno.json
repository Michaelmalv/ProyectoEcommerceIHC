{
  "tasks": {
    "dev": "deno run --allow-all supabase/functions/server/index.tsx"
  },
  "imports": {
    "hono": "npm:hono@*",
    "hono/": "npm:hono/",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2"
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
